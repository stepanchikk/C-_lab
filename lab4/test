using Microsoft.VisualStudio.TestTools.UnitTesting;
using Lab4;

namespace Lab4_Tests
{
    [TestClass]
    public class VectorShortTests
    {
        [TestMethod]
        public void TestVectorOperators()
        {
            
            VectorShort v1 = new VectorShort(3, 5);
            VectorShort v2 = new VectorShort(3, 2);

        
            VectorShort v3 = v1 + v2;

            Assert.AreEqual((short)7, v3[0], "Оператор + працює неправильно");
            Assert.AreEqual((short)7, v3[2], "Оператор + працює неправильно для останнього елемента");

            Assert.IsTrue(v1 != v2, "Вектори мають бути різними");

            VectorShort v4 = new VectorShort(3, 5);
            Assert.IsTrue(v1 == v4, "Вектори з однаковими даними мають бути рівними");

            v2++;
            Assert.AreEqual((short)3, v2[1], "Оператор ++ працює неправильно");
        }
    }
}
