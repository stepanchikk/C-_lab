        public static VectorShort operator <<(VectorShort v1, VectorShort v2) { uint max = Math.Max(v1.n, v2.n); var r = new VectorShort(max); for (int i = 0; i < max; i++) r[i] = (short)((i < v1.n ? v1[i] : 0) << (i < v2.n ? v2[i] : 0)); return r; }
