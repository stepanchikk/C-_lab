        public static bool operator ==(VectorShort v1, VectorShort v2) { if (ReferenceEquals(v1, v2)) return true; if (v1 is null || v2 is null || v1.n != v2.n) return false; for (int i = 0; i < v1.n; i++) if (v1[i] != v2[i]) return false; return true; }
