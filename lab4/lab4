        public static VectorShort operator *(VectorShort v1, VectorShort v2) { uint max = Math.Max(v1.n, v2.n); var r = new VectorShort(max); for (int i = 0; i < max; i++) r[i] = (short)((i < v1.n ? v1[i] : 0) * (i < v2.n ? v2[i] : 0)); return r; }
        public static VectorShort operator *(VectorShort v, short s) { var r = new VectorShort(v.n); for (int i = 0; i < v.n; i++) r[i] = (short)(v[i] * s); return r; }

        public static VectorShort operator /(VectorShort v1, VectorShort v2) { uint max = Math.Max(v1.n, v2.n); var r = new VectorShort(max); for (int i = 0; i < max; i++) { short b = i < v2.n ? v2[i] : (short)1; r[i] = b != 0 ? (short)((i < v1.n ? v1[i] : 0) / b) : (short)0; } return r; }
