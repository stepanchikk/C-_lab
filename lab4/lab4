    // ЗАВДАННЯ 4.3: Клас MatrixShort
    public class MatrixShort
    {
        protected short[,] ShortArray;
        protected int n, m;
        protected int codeError;
        public static int num_m;

        // Конструктори
        public MatrixShort() { n = 1; m = 1; ShortArray = new short[1, 1]; num_m++; }
        public MatrixShort(int rows, int cols) { n = rows; m = cols; ShortArray = new short[n, m]; num_m++; }
        public MatrixShort(int rows, int cols, short init)
        {
            n = rows; m = cols; ShortArray = new short[n, m];
            for (int i = 0; i < n; i++) for (int j = 0; j < m; j++) ShortArray[i, j] = init;
            num_m++;
        }
        ~MatrixShort() { } // Деструктор

        public int Rows => n;
        public int Cols => m;
        public int CodeError { get => codeError; set => codeError = value; }

        // 2D індексатор
        public short this[int i, int j]
        {
            get { if (i < 0 || i >= n || j < 0 || j >= m) { codeError = -1; return 0; } return ShortArray[i, j]; }
            set { if (i < 0 || i >= n || j < 0 || j >= m) { codeError = -1; } else ShortArray[i, j] = value; }
        }

        // 1D індексатор
        public short this[int k]
        {
            get { int i = k / m; int j = k % m; return this[i, j]; }
            set { int i = k / m; int j = k % m; this[i, j] = value; }
        }

        public void Input()
        {
            for (int i = 0; i < n; i++)
                for (int j = 0; j < m; j++)
                {
                    Console.Write($"M[{i},{j}] = ");
                    ShortArray[i, j] = short.Parse(Console.ReadLine());
                }
        }

        public void Print()
        {
            for (int i = 0; i < n; i++)
            {
                for (int j = 0; j < m; j++) Console.Write(ShortArray[i, j] + "\t");
                Console.WriteLine();
            }
        }

        public void AssignAll(short val) { for (int i = 0; i < n; i++) for (int j = 0; j < m; j++) ShortArray[i, j] = val; }
        public static int GetCount() => num_m;

        // Унарні оператори
        public static MatrixShort operator ++(MatrixShort mat) { var r = new MatrixShort(mat.n, mat.m); for (int i = 0; i < mat.n; i++) for (int j = 0; j < mat.m; j++) r[i, j] = (short)(mat[i, j] + 1); return r; }
        public static MatrixShort operator --(MatrixShort mat) { var r = new MatrixShort(mat.n, mat.m); for (int i = 0; i < mat.n; i++) for (int j = 0; j < mat.m; j++) r[i, j] = (short)(mat[i, j] - 1); return r; }
        public static bool operator true(MatrixShort mat) { if (mat.n == 0 || mat.m == 0) return false; foreach (short v in mat.ShortArray) if (v == 0) return false; return true; }
        public static bool operator false(MatrixShort mat) { if (mat.n == 0 || mat.m == 0) return true; foreach (short v in mat.ShortArray) if (v != 0) return false; return true; }
        public static bool operator !(MatrixShort mat) => mat.n == 0 || mat.m == 0;
        public static MatrixShort operator ~(MatrixShort mat) { var r = new MatrixShort(mat.n, mat.m); for (int i = 0; i < mat.n; i++) for (int j = 0; j < mat.m; j++) r[i, j] = (short)~mat[i, j]; return r; }

        // Арифметичні (+, -, *, /, %) - Повертає першу матрицю при різних розмірах
        public static MatrixShort operator +(MatrixShort m1, MatrixShort m2) { var r = new MatrixShort(m1.n, m1.m); for (int i = 0; i < m1.n; i++) for (int j = 0; j < m1.m; j++) r[i, j] = (short)(m1[i, j] + (i < m2.n && j < m2.m ? m2[i, j] : 0)); return r; }
