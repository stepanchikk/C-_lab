    // ЗАВДАННЯ 1.3: Клас Rectangle
    public class Rectangle
    {
        protected int a, b;
        protected int c;

        public Rectangle(int a, int b, int c)
        {
            this.a = a; this.b = b; this.c = c;
        }

        // Індексатор
        public int this[int index]
        {
            get
            {
                if (index == 0) return a;
                if (index == 1) return b;
                if (index == 2) return c;
                throw new IndexOutOfRangeException("Помилка: невірний індекс!");
            }
            set
            {
                if (index == 0) a = value;
                else if (index == 1) b = value;
                else if (index == 2) c = value;
                else throw new IndexOutOfRangeException("Помилка: невірний індекс!");
            }
        }

        // Перевантаження операторів
        public static Rectangle operator ++(Rectangle r) { r.a++; r.b++; return r; }
        public static Rectangle operator --(Rectangle r) { r.a--; r.b--; return r; }
        public static bool operator true(Rectangle r) => r.a == r.b;
        public static bool operator false(Rectangle r) => r.a != r.b;
        public static Rectangle operator *(Rectangle r, int scalar) => new Rectangle(r.a * scalar, r.b * scalar, r.c);

        // Перетворення типів
        public static implicit operator string(Rectangle r) => $"{r.a},{r.b},{r.c}";
        public static explicit operator Rectangle(string s)
        {
            var parts = s.Split(',');
            return new Rectangle(int.Parse(parts[0]), int.Parse(parts[1]), int.Parse(parts[2]));
        }

        public override string ToString() => $"Прямокутник {a}x{b}, колір {c}";
    }

    // ЗАВДАННЯ 2.3: Клас VectorShort
    public class VectorShort
    {
        protected short[] ShortArray;
        protected uint n;
        protected uint codeError;
        public static uint num_v;

        public VectorShort() { n = 1; ShortArray = new short[1]; num_v++; }
        public VectorShort(uint size) { n = size; ShortArray = new short[n]; num_v++; }
        public VectorShort(uint size, short initValue)
        {
            n = size; ShortArray = new short[n];
            for (int i = 0; i < n; i++) ShortArray[i] = initValue;
            num_v++;
        }
        ~VectorShort() {}

        public uint Size => n;
        public uint CodeError { get => codeError; set => codeError = value; }

        public short this[int i]
        {
            get { if (i < 0 || i >= n) { codeError = 10; return 0; } return ShortArray[i]; }
            set { if (i < 0 || i >= n) { codeError = 10; } else ShortArray[i] = value; }
        }

        public void Input()
        {
            for (int i = 0; i < n; i++)
            {
                Console.Write($"v[{i}] = ");
                ShortArray[i] = short.Parse(Console.ReadLine());
            }
        }
        public void Print() => Console.WriteLine($"[{string.Join(", ", ShortArray)}]");
        public void AssignAll(short val) { for (int i = 0; i < n; i++) ShortArray[i] = val; }
        public static uint GetCount() => num_v;

        // Унарні оператори
        public static VectorShort operator ++(VectorShort v) { var r = new VectorShort(v.n); for (int i = 0; i < v.n; i++) r[i] = (short)(v[i] + 1); return r; }
        public static VectorShort operator --(VectorShort v) { var r = new VectorShort(v.n); for (int i = 0; i < v.n; i++) r[i] = (short)(v[i] - 1); return r; }
        public static bool operator true(VectorShort v) => v.n != 0 || v.ShortArray.Any(x => x != 0);
        public static bool operator false(VectorShort v) => v.n == 0 && v.ShortArray.All(x => x == 0);
        public static bool operator !(VectorShort v) => v.n == 0;
        public static VectorShort operator ~(VectorShort v) { var r = new VectorShort(v.n); for (int i = 0; i < v.n; i++) r[i] = (short)~v[i]; return r; }

        // Арифметичні (+, -, *, /, %) з обробкою різних розмірів
        public static VectorShort operator +(VectorShort v1, VectorShort v2) { uint max = Math.Max(v1.n, v2.n); var r = new VectorShort(max); for (int i = 0; i < max; i++) r[i] = (short)((i < v1.n ? v1[i] : 0) + (i < v2.n ? v2[i] : 0)); return r; }
        public static VectorShort operator +(VectorShort v, short s) { var r = new VectorShort(v.n); for (int i = 0; i < v.n; i++) r[i] = (short)(v[i] + s); return r; }

        public static VectorShort operator -(VectorShort v1, VectorShort v2) { uint max = Math.Max(v1.n, v2.n); var r = new VectorShort(max); for (int i = 0; i < max; i++) r[i] = (short)((i < v1.n ? v1[i] : 0) - (i < v2.n ? v2[i] : 0)); return r; }
