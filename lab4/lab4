            Console.WriteLine("1. Масив Структур:");
            structBuyers.ForEach(b => Console.WriteLine(b));

            // 2. Кортежі
            List<(string Name, string Phone)> tupleBuyers = new()
            {
                ("Іван", "111"), ("Петро", "222"), ("Олег", "333"), ("Анна", "444")
            };
            if (tupleBuyers.Count >= 3) tupleBuyers.RemoveRange(0, 3);
            tupleBuyers.Add(("Новий1", "555")); tupleBuyers.Add(("Новий2", "666")); tupleBuyers.Add(("Новий3", "777"));
            Console.WriteLine("\n2. Кортежі:");
            tupleBuyers.ForEach(b => Console.WriteLine($"Кортеж: {b.Name}, {b.Phone}"));

            // 3. Записи (Records) та Словники (Dictionary)
            Dictionary<string, BuyerRecord> recordDict = new()
            {
                { "111", new BuyerRecord("Іван", "Київ", "111", "0000") },
                { "222", new BuyerRecord("Петро", "Львів", "222", "1111") },
                { "333", new BuyerRecord("Олег", "Одеса", "333", "2222") },
                { "444", new BuyerRecord("Анна", "Дніпро", "444", "3333") }
            };
            recordDict.Remove("111"); recordDict.Remove("222"); recordDict.Remove("333");
            recordDict.Add("555", new BuyerRecord("Новий1", "-", "555", "-"));
            recordDict.Add("666", new BuyerRecord("Новий2", "-", "666", "-"));
            recordDict.Add("777", new BuyerRecord("Новий3", "-", "777", "-"));
            Console.WriteLine("\n3. Словник Записів:");
            foreach (var kvp in recordDict) Console.WriteLine($"Ключ: {kvp.Key} -> {kvp.Value}");

            //ЗАВДАННЯ 2.3 ТА 4.3 (ДЕМОНСТРАЦІЯ ОПЕРАТОРІВ)
            Console.WriteLine("\nЗАВДАННЯ 2.3 ТА 4.3: ВЕКТОРИ Й МАТРИЦІ");

            VectorShort v = new VectorShort(3, 5);
            MatrixShort m = new MatrixShort(2, 3, 2);

            Console.WriteLine("Матриця M (2x3):"); m.Print();
            Console.WriteLine("Вектор V (розмір 3):"); v.Print();

            VectorShort vResult = m * v; // Множення матриці на вектор згідно з перевантаженням
            Console.WriteLine("Результат M * V (Вектор розміру 2):"); vResult.Print();

            Console.ReadLine();
